# Required
NETBOX_URL=https://netbox.example.com
NETBOX_TOKEN=your_netbox_api_token_here

# Optional: timezone
TZ=UTC

# Optional: domain suffix for devices without a primary IP
# When set, devices without an IP get name + suffix as connection target
# Example: DOMAIN_SUFFIX=.example.com → "router01" becomes "router01.example.com"
DOMAIN_SUFFIX=

# Optional: NetBox API query filters
# Uses NetBox's standard device filter parameters.
# Multiple values for the same field use repeated params: role=router&role=switch
#
# Common filters:
#   status=active                    → only active devices
#   role=voice-gateway               → by device role slug
#   manufacturer=cisco               → by manufacturer slug
#   tag=oxidized                     → by tag slug
#   region=us-west                   → by region slug
#   site=hq                          → by site slug
#   platform=ios                     → by platform slug
#   limit=0                          → return all results (no pagination)
#
# Default: all active devices
DEVICE_FILTERS=status=active&limit=0

# Optional: HTTP server port (default: 8080)
LISTEN_PORT=8080
